import pandas as pd
import matplotlib.pyplot as plt


df = pd.read_csv('Zara_sales_EDA.csv', sep=';', index_col='Product ID')



#print(df.isnull().sum())  #to check for null values in each column
#print(df.head())          #to print first 5 elements
#print(df.info())          #to print num (of columns & rows & non-null & storage)
#print(df.shape)            #to print the number of rows and columns
#print(df.describe())       #to print the statistical summary of the numerical columns
#print(df.duplicated().sum()) #to check for duplicate rows in the dataset
#Data Cleaning 

df['name']=df['name'].fillna("Unknown")  #replace the null values with "Unknown"
df['description']=df['description'].fillna("Unknown")  #replace the null values with "Unknown"
#print(df.duplicated().sum())


plt.style.use("dark_background")
df["price"].hist(color='cyan')  #to visualize the distribution of the price column
plt.title("Price Distribution", fontsize=10)
plt.xlabel("Price", fontsize=10)
plt.ylabel("Frequency", fontsize=10)

plt.xticks()  
plt.yticks()  
plt.tight_layout()
plt.show()


df["Sales Volume"].hist(color='cyan')  #to visualize the distribution of the sales volume column
plt.title("Sales Volume Distribution", fontsize=10)
plt.xlabel("Sales Volume", fontsize=10)
plt.ylabel("Frequency", fontsize=10)
plt.xticks()  
plt.yticks()  
plt.tight_layout()
plt.show()


df["Promotion"].value_counts().plot(kind='bar',color='cyan')  #to visualize the count of each category in the Promotion column
plt.title("Promotion Count", fontsize=10)
plt.xlabel("Promotion", fontsize=10)
plt.ylabel("Count", fontsize=10)  
plt.tight_layout()   
plt.show()

df["section"].value_counts().plot(kind='bar',color='cyan')  #to visualize the count of each category in the Promotion column
plt.title("Section Count", fontsize=10)
plt.xlabel("Section", fontsize=10)
plt.ylabel("Count", fontsize=10)     
plt.tight_layout()
plt.show()


df["season"].value_counts().plot(kind='bar',color='cyan')  #to visualize the count of each category in the Promotion column
plt.title("Season Count", fontsize=10)
plt.xlabel("Season", fontsize=10)
plt.ylabel("Count", fontsize=10)  
plt.tight_layout()   
plt.show()

##bivariate analysis    




plt.scatter(df["Sales Volume"], df["price"], alpha=0.3, s=10 ,color='cyan')  #to visualize the relationship between sales volume and price
plt.title("Sales Volume vs Price", fontsize=10)
plt.xlabel("Sales Volume", fontsize=10)
plt.ylabel("Price", fontsize=10)
plt.tight_layout()
plt.show()

df.groupby("Promotion")["Sales Volume"].mean().plot(kind="bar",color='cyan')  #to visualize the average sales volume for each promotion category
plt.title("Average Sales Volume by Promotion", fontsize=10)
plt.xlabel("Promotion", fontsize=10)
plt.ylabel("Average Sales Volume", fontsize=10)
plt.tight_layout()
plt.show()



###multivariate analysis

df.groupby(["Product Category","Promotion"])["Sales Volume"].mean().plot(kind='bar',color='cyan')  #to visualize the average sales volume for each product category and promotion category
plt.title("Average Sales Volume by Product Category and Promotion", fontsize=10)
plt.xlabel("Category & Promotion", fontsize=10)
plt.ylabel("Sales Volume", fontsize=10)
plt.tight_layout()
plt.show()


df.groupby(["section","season"])['Sales Volume'].mean().plot(kind='bar',color='cyan')  #to visualize the average sales volume for each section and season
plt.title("Average Sales Volume by Section and Season", fontsize=10)   
plt.xlabel("Section & Season", fontsize=10)
plt.ylabel("Sales Volume", fontsize=10)
plt.tight_layout()
plt.show()